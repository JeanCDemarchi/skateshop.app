# ===== Banco de dados (Supabase Postgres, usado pelo Prisma) =====
# Connection string com pgbouncer (pooled) para a aplicação:
DATABASE_URL="postgresql://usuario:senha@host:6543/postgres?pgbouncer=true"
# Connection string direta (sem pooler), usada em migrations:
DIRECT_URL="postgresql://usuario:senha@host:5432/postgres"

# ===== Supabase (SDK / Storage / Admin) =====
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_KEY="sua-service-role-key"

# ===== Autenticação =====
JWT_SECRET="troque-por-um-segredo-bem-forte"

# ===== Servidor =====
PORT=3333
