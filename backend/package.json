{
  "name": "skateshop-backend",
  "version": "1.0.0",
  "description": "Backend da Skateshop - Node.js + Express + Prisma",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "clearMocks": true,
    "restoreMocks": true,
    "collectCoverageFrom": [
      "src/utils/**/*.js",
      "src/middlewares/**/*.js",
      "src/services/**/*.js",
      "src/controllers/**/*.js"
    ]
  }
}
